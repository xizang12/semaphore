---
- name: Update all packages on Debian/Ubuntu hosts
  hosts: debian_hosts
  become: true  # Required to run with root privileges
  tasks:
    - name: Update apt package cache and upgrade all installed packages
      ansible.builtin.apt:
        update_cache: yes
        cache_valid_time: 3600  # Update cache if older than 1 hour (3600s)
        upgrade: yes
    - name: Check if reboot is required (Debian/Ubuntu)
      stat:
        path: /var/run/reboot-required
      register: reboot_required_file
    - name: Send Pushover notification
      community.general.pushover:
        user_key: 'abttthxtsupgm6ts2hh8ia7j114dpr'
        app_token: 'uwachpdmhh1xvpbp39pebv6jzvbxes'
        msg: "Host {{ ansible_hostname }} requires a reboot."
        title: "Reboot Required"
      when: reboot_required_file.stat.exists

- name: Update all packages on Alpine Linux hosts
  hosts: alpine_hosts
  become: true  # Required to run with root privileges
  tasks:
    - name: Update apk package cache and upgrade all installed packages
      community.general.apk:
        update_cache: yes
        upgrade: yes
    - name: Check if kernel update requires a reboot
      ansible.builtin.command:
        cmd: "set -o pipefail; apk -u list | grep '^linux-'"
      register: kernel_update_check
      ignore_errors: true # Ignore errors because grep will return exit code 1 if no kernel packages are listed
      changed_when: kernel_update_check.rc == 0

    - name: Send Pushover notification
      community.general.pushover:
        user_key: 'abttthxtsupgm6ts2hh8ia7j114dpr'
        app_token: 'uwachpdmhh1xvpbp39pebv6jzvbxes'
        msg: "Host {{ ansible_hostname }} requires a reboot."
        title: "Reboot Required"
      when: kernel_update_check.rc == 0

